# Environment Variables — copy this file to .env and fill in real values
# Never commit the actual .env file!

# ─── Frontend (React / Vercel) ─────────────────────────────────────────────────
# The URL of your Render backend (Socket.IO server)
# Set this in your Vercel project → Settings → Environment Variables
REACT_APP_BACKEND_URL=https://your-render-service.onrender.com

# ─── Backend (Node / Render) ───────────────────────────────────────────────────
# Port the server listens on (Render sets this automatically)
PORT=5000

# Comma-separated list of allowed origins for CORS
# Example: https://your-app.vercel.app,http://localhost:3000
CORS_ORIGIN=https://your-app.vercel.app,http://localhost:3000
